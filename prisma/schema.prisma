generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  // pg_stat_statements, pgcrypto, supabase_vault, uuid-ossp are enabled by
  // Supabase automatically on every project, not by a Prisma migration —
  // declared here so Prisma recognizes they already exist instead of
  // reporting them as schema drift. pg_trgm is the one this project added.
  extensions = [pg_trgm, pg_stat_statements, pgcrypto, supabase_vault(schema: "vault"), uuid_ossp(map: "uuid-ossp")]
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  name        String?
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())

  wines           Wine[]
  alerts          CellarAlert[]
  conversations   AiConversation[]
  imports         Import[]
  consumptionLogs ConsumptionLog[]
  tastingNotes    TastingNote[]
  watchListItems  WatchListItem[]

  @@map("users")
}

model Wine {
  id                 String    @id @default(cuid())
  userId             String
  producer           String
  wineName           String
  vintage            Int?
  country            String?
  state              String?
  region             String?
  subRegion          String?
  appellation        String?
  vineyard           String?
  classification     String?
  varietal           String?
  format             String?
  style              String?
  quantity           Int       @default(1)
  purchasePrice      Decimal?  @db.Decimal(10, 2)
  purchaseDate       DateTime?
  vendor             String?
  storageLocation    String?
  notes              String?
  tastingNotes       String?
  pairingNotes       String?
  // Rule (added 2026-07-20): rating, and every manually-entered field below
  // it on this model, is the user's own input. No sync, enrichment refresh,
  // or wine_knowledge catalog update may ever overwrite a value the user
  // entered themselves — catalog/enrichment data only fills fields the user
  // left blank, same "fill blanks, never overwrite" rule used elsewhere in
  // this design (see PHASE2_READINESS.md).
  rating             Decimal?  @db.Decimal(4, 1)
  drinkWindowStart   Int?
  drinkWindowEnd     Int?
  currentEstValue    Decimal?  @db.Decimal(10, 2)
  totalCostOverride  Decimal?  @db.Decimal(10, 2)
  totalValueOverride Decimal?  @db.Decimal(10, 2)
  consumedQuantity   Int       @default(0)
  isFullyConsumed    Boolean   @default(false)
  wineId             String?
  labelPhotoUrl      String?
  importId           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  import          Import?          @relation(fields: [importId], references: [id])
  enrichment      WineEnrichment?
  alerts          CellarAlert[]
  importRows      ImportRow[]
  consumptionLogs ConsumptionLog[]

  @@index([userId])
  @@index([importId])
  @@map("wines")
}

model ConsumptionLog {
  id           String   @id @default(cuid())
  wineId       String
  userId       String
  quantity     Int      @default(1)
  consumedDate DateTime @default(now())
  occasion     String?
  notes        String?
  rating       Decimal? @db.Decimal(4, 1)
  createdAt    DateTime @default(now())

  wine Wine @relation(fields: [wineId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wineId])
  @@index([userId])
  @@map("consumption_logs")
}

model WineEnrichment {
  id                 String    @id @default(cuid())
  wineId             String    @unique
  criticScores       Json?
  currentMarketPrice Decimal?  @db.Decimal(10, 2)
  drinkWindowStart   Int?
  drinkWindowEnd     Int?
  peakWindowStart    Int?
  peakWindowEnd      Int?
  lastEnrichedAt     DateTime?

  wine Wine @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@map("wine_enrichments")
}

model CellarAlert {
  id          String    @id @default(cuid())
  userId      String
  wineId      String?
  alertType   String
  message     String?
  triggerDate DateTime
  deliveredAt DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wine Wine? @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([wineId])
  @@map("cellar_alerts")
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_conversations")
}

enum ImportSourceType {
  EXCEL
  CSV
  PDF
  IMAGE
}

enum ImportStatus {
  PENDING
  PROCESSING
  REVIEW
  COMPLETE
  FAILED
}

enum ImportType {
  NEW_INVENTORY
  MATCH_CONSUMED
  HISTORICAL_CONSUMED
}

model Import {
  id                     String           @id @default(cuid())
  userId                 String
  sourceType             ImportSourceType
  originalFilename       String
  storagePath            String
  status                 ImportStatus     @default(PENDING)
  recordCount            Int              @default(0)
  skippedCount           Int              @default(0)
  errorMessage           String?
  importType             ImportType       @default(NEW_INVENTORY)
  isHistoricalImport     Boolean          @default(false)
  historicalConsumedDate DateTime?
  createdAt              DateTime         @default(now())
  completedAt            DateTime?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wines Wine[]
  rows  ImportRow[]

  @@index([userId])
  @@map("imports")
}

enum ImportRowStatus {
  PENDING
  CONFIRMED
  SKIPPED
}

model ImportRow {
  id               String          @id @default(cuid())
  importId         String
  rawData          Json
  mappedData       Json?
  confidenceScores Json?
  status           ImportRowStatus @default(PENDING)
  wineId           String?
  reviewNotes      String?

  import Import @relation(fields: [importId], references: [id], onDelete: Cascade)
  wine   Wine?  @relation(fields: [wineId], references: [id])

  @@index([importId])
  @@index([wineId])
  @@map("import_rows")
}

model TastingNote {
  id         String   @id @default(cuid())
  userId     String
  producer   String
  wineName   String
  vintage    Int?
  rating     Decimal? @db.Decimal(4, 1)
  liked      Boolean?
  notes      String?
  occasion   String?
  photoUrl   String?
  tastedDate DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasting_notes")
}

// Shared wine catalog — NOT per-user data. See PHASE2_READINESS.md for the
// full design (dedup matching, privacy allow-list, trust-tier resolution,
// search indexing). Deliberately carries zero relations to User, Import,
// ImportRow, or Wine, and zero fields describing a person's private cellar
// (price, storage location, notes, vendor) — see the privacy design doc
// before adding any field here.
enum SourceTrust {
  X_WINES // primary anchor, CC0-licensed catalog import
  LWIN // reserved — not populated until LWIN is licensed (deferred, see plan doc)
  USER_CONFIRMED // written back from a real user's confirmed cellar import
  LEGACY_MANUAL // the hand-curated 539-wine wine-data.json — real curated
  // data, but unverified against a licensed source, so it
  // ranks below X_WINES/LWIN and above AI_ESTIMATE
  VIVINO // live lookup fallback, matches today's enrichment behavior
  AI_ESTIMATE // lowest trust — an AI guess with nothing to check it against
}

model WineKnowledge {
  id String @id @default(cuid())

  // Core identity — what wine this is
  producer String
  wineName String
  vintage  Int? // a specific year — only ever set for a user-confirmed, bottle-specific
  // entry. null = either non-vintage (NV), or a catalog-level entry (see
  // known_vintages below) that isn't tied to one specific bottle.

  // Added 2026-07-20. One row per wine, not per year: a catalog source like
  // X-Wines lists the range of years a wine has been produced, with every
  // other field identical across them — exploding that into one row per
  // year would multiply ~100,646 wines into 800,000+ near-duplicates. This
  // holds that year list on catalog-level rows. Never set alongside a
  // populated `vintage` — a row is either a specific bottle (vintage set,
  // this null) or a catalog entry spanning years (this set, vintage null).
  known_vintages Int[]

  // Added 2026-07-20: whether this wine is also/only sold as non-vintage
  // (e.g. most Champagne blends). Separate from known_vintages because a
  // wine can have both real years AND an NV bottling -- dropping the NV
  // fact to fit it into a numeric-only years list was the wrong call
  // (corrected same day). Default false, not null: every X-Wines row has
  // a real answer to this (checked directly), so there's no "unknown" case
  // for that source the way there is for a hand-entered user import.
  has_non_vintage Boolean @default(false)

  // Geography — a real hierarchy (country > state > region > subRegion >
  // appellation), not independent facts. Kept as flat columns rather than a
  // separate linked table: spelling/hierarchy consistency is already
  // enforced upstream, at write time, by the same normalization logic used
  // for dedup — a linked table would re-solve a problem that's already
  // solved, at the cost of a join on every read. Revisit only if a real
  // feature needs relational geography queries this doesn't support today.
  country     String?
  state       String?
  region      String?
  subRegion   String?
  appellation String?

  // Sparse, wine-specific detail — not geography, and typically unknown.
  // Both fields are filled well under 30% of the time in practice; absence
  // is the normal case, not a data-quality problem.
  vineyard       String?
  classification String?

  // Varietal — deliberately separate from the two groups above. Unlike
  // geography or vineyard/classification, this is not always a fixed fact:
  // a producer can change a wine's blend composition over time. A
  // vintage-dated wine's blend change is naturally captured as a new
  // vintage (its own row here) — the real edge case is a non-vintage (NV)
  // wine, which has no vintage year to split by, so its varietal can only
  // ever reflect the most recently confirmed value, not a permanent fact.
  // Known limitation, not solved by this schema — documented so it's never
  // mistaken for a data-quality bug.
  varietal String?

  // Wine type/style (Red, White, Rosé, Sparkling, Dessert, Fortified). Added
  // 2026-07-20 — maps to X-Wines' "Type" column, which had nowhere to land
  // without this. Nullable: not every source (LWIN, user imports,
  // AI-estimate) will supply it, same as vineyard/classification above.
  type_style String?

  // Sensory/descriptive facts — added 2026-07-20, all from the same gap
  // review as type_style above. All nullable, same reasoning throughout:
  // not every source supplies every field.
  abv               Decimal? @db.Decimal(4, 2) // alcohol by volume, e.g. 13.50
  body              String? // e.g. Light-bodied / Medium-bodied / Full-bodied
  acidity           String? // e.g. Low / Medium / High
  website           String? // producer/winery's own site
  pairing_notes     String? // renamed from X-Wines' "Harmonize" (food pairing suggestions)
  blend_composition String? // renamed from X-Wines' "Elaborate" (e.g. "Varietal/100%", "Assemblage/Blend")

  // Dedup fields — computed at write time (accent-folded, punctuation
  // stripped, abbreviations expanded), never shown to a user directly.
  // See PHASE2_READINESS.md "Dedup matching" for the matching logic that
  // populates and uses these.
  normalizedProducer String
  normalizedWineName String
  searchText         String // normalizedProducer + ' ' + normalizedWineName, for search only

  // Source-trust — real enum column (not a JSON blob) so conflict
  // resolution can filter/sort at scale. Same-tier conflicts resolve by
  // fill-blanks-only, never overwrite (see PHASE2_READINESS.md).
  sourceTrust SourceTrust

  // Source-specific identifiers — separate nullable columns per source,
  // since each source's ID namespace is only unique within itself.
  xWinesId        String? @unique
  lwinCode        String? @unique // populated once LWIN is licensed
  lwinStatus      String?
  lwinDisplayName String?

  // Rating — one precomputed aggregate only. Never individual rating rows
  // (X-Wines' 21M ratings are deliberately not imported — see plan doc).
  avgRating   Decimal? @db.Decimal(3, 2)
  ratingCount Int?

  // Wine-Searcher pricing placeholder — populated once that license is
  // pursued (bundled decision with LWIN, deferred).
  wineSearcherPrice Decimal? @db.Decimal(10, 2)

  // Anonymous multi-confirmation counter — a plain count only, never a
  // list of who confirmed it. See privacy design in PHASE2_READINESS.md.
  confirmedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Deliberately absent, on principle: userId, importId, wineId,
  // purchasePrice, storageLocation, vendor, notes, tastingNotes,
  // pairingNotes, or any per-contributor identifier.

  @@index([normalizedProducer, normalizedWineName, vintage]) // dedup exact-key fast path
  @@index([producer]) // B-tree, exact/prefix browse
  @@index([sourceTrust]) // conflict-resolution queries
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin) // fuzzy search
  @@map("wine_knowledge")
}

// Region/appellation hierarchy reference — added 2026-07-20 as part of the
// region-validation checker (lib/wines/region-hierarchy-checker.ts). Deliberately
// a separate table from wine_knowledge, not a patch to lib/wines/wine-knowledge.ts:
// that file is a small, hand-curated TS object read for live autocomplete/spelling
// correction; this is a bulk, sourced reference queried programmatically against
// the ~100K-row X-Wines import. See WINE_KNOWLEDGE_DATABASE_PLAN.md,
// "Region-Hierarchy Source Evaluation (2026-07-20)" for how each source below
// was actually verified.
enum RegionAuthoritySource {
  WIKIDATA // primary — P131 (located in) / P17 (country) on items typed `instance of: wine` (Q282)
  WINERYMAP // secondary cross-check — github.com/oOo0oOo/winerymap, MIT licensed
}

model RegionAuthority {
  id String @id @default(cuid())

  appellation String // e.g. "Colli di Scandiano e di Canossa DOC"
  locatedIn   String? // e.g. "Province of Reggio Emilia" (Wikidata P131) — nullable, some source rows lack it
  country     String? // e.g. "Italy"

  source     RegionAuthoritySource
  externalId String? // Wikidata Q-id when source = WIKIDATA; null for WineryMap (no stable per-region id in that source)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appellation])
  @@index([country])
  @@map("region_authority")
}

model WatchListItem {
  id         String    @id @default(cuid())
  userId     String
  producer   String
  wineName   String?
  vintage    Int?
  notes      String?
  targetDate DateTime?
  notified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("watch_list_items")
}
