generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  name        String?
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())

  wines            Wine[]
  alerts           CellarAlert[]
  conversations    AiConversation[]
  imports          Import[]
  consumptionLogs  ConsumptionLog[]
  tastingNotes     TastingNote[]
  watchListItems   WatchListItem[]

  @@map("users")
}

model Wine {
  id              String    @id @default(cuid())
  userId          String
  producer        String
  wineName        String
  vintage         Int?
  country         String?
  state           String?
  region          String?
  subRegion       String?
  vineyard        String?
  classification  String?
  varietal        String?
  format          String?
  style           String?
  quantity        Int       @default(1)
  purchasePrice   Decimal?  @db.Decimal(10, 2)
  purchaseDate    DateTime?
  vendor          String?
  storageLocation String?
  notes           String?
  tastingNotes    String?
  pairingNotes    String?
  rating          Decimal?  @db.Decimal(4, 1)
  drinkWindowStart Int?
  drinkWindowEnd   Int?
  currentEstValue  Decimal?  @db.Decimal(10, 2)
  totalCostOverride  Decimal? @db.Decimal(10, 2)
  totalValueOverride Decimal? @db.Decimal(10, 2)
  consumedQuantity Int       @default(0)
  isFullyConsumed  Boolean   @default(false)
  wineId          String?
  labelPhotoUrl   String?
  importId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  import          Import?           @relation(fields: [importId], references: [id])
  enrichment      WineEnrichment?
  alerts          CellarAlert[]
  importRows      ImportRow[]
  consumptionLogs ConsumptionLog[]

  @@index([userId])
  @@index([importId])
  @@map("wines")
}

model ConsumptionLog {
  id           String    @id @default(cuid())
  wineId       String
  userId       String
  quantity     Int       @default(1)
  consumedDate DateTime  @default(now())
  occasion     String?
  notes        String?
  rating       Decimal?  @db.Decimal(4, 1)
  createdAt    DateTime  @default(now())

  wine Wine @relation(fields: [wineId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wineId])
  @@index([userId])
  @@map("consumption_logs")
}

model WineEnrichment {
  id                 String    @id @default(cuid())
  wineId             String    @unique
  criticScores       Json?
  currentMarketPrice Decimal?  @db.Decimal(10, 2)
  drinkWindowStart   Int?
  drinkWindowEnd     Int?
  peakWindowStart    Int?
  peakWindowEnd      Int?
  lastEnrichedAt     DateTime?

  wine Wine @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@map("wine_enrichments")
}

model CellarAlert {
  id          String    @id @default(cuid())
  userId      String
  wineId      String?
  alertType   String
  message     String?
  triggerDate DateTime
  deliveredAt DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  wine Wine? @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([wineId])
  @@map("cellar_alerts")
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_conversations")
}

enum ImportSourceType {
  EXCEL
  CSV
  PDF
  IMAGE
}

enum ImportStatus {
  PENDING
  PROCESSING
  REVIEW
  COMPLETE
  FAILED
}

model Import {
  id               String           @id @default(cuid())
  userId           String
  sourceType       ImportSourceType
  originalFilename String
  storagePath      String
  status           ImportStatus     @default(PENDING)
  recordCount      Int              @default(0)
  skippedCount     Int              @default(0)
  errorMessage     String?
  createdAt        DateTime         @default(now())
  completedAt      DateTime?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wines Wine[]
  rows  ImportRow[]

  @@index([userId])
  @@map("imports")
}

enum ImportRowStatus {
  PENDING
  CONFIRMED
  SKIPPED
}

model ImportRow {
  id               String          @id @default(cuid())
  importId         String
  rawData          Json
  mappedData       Json?
  confidenceScores Json?
  status           ImportRowStatus @default(PENDING)
  wineId           String?
  reviewNotes      String?

  import Import @relation(fields: [importId], references: [id], onDelete: Cascade)
  wine   Wine?   @relation(fields: [wineId], references: [id])

  @@index([importId])
  @@index([wineId])
  @@map("import_rows")
}

model TastingNote {
  id         String    @id @default(cuid())
  userId     String
  producer   String
  wineName   String
  vintage    Int?
  rating     Decimal?  @db.Decimal(4, 1)
  liked      Boolean?
  notes      String?
  occasion   String?
  photoUrl   String?
  tastedDate DateTime  @default(now())
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasting_notes")
}

model WatchListItem {
  id         String    @id @default(cuid())
  userId     String
  producer   String
  wineName   String?
  vintage    Int?
  notes      String?
  targetDate DateTime?
  notified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("watch_list_items")
}
