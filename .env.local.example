# Copy this file to .env.local and fill in real values.
# DATABASE_URL and DIRECT_URL go in .env instead (Prisma CLI loads .env automatically).

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Settings > Database > Connection string) -- set in .env, not here
# DATABASE_URL=
# DIRECT_URL=

# Anthropic Claude API (server-side only, never expose to client)
ANTHROPIC_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Vercel Cron secret (used to authenticate cron job requests)
CRON_SECRET=

# Wine-Searcher (enrichment + autocomplete -- Phase 5)
WINE_SEARCHER_API_KEY=
